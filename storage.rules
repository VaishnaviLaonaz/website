rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isAllowedImageSize(maxBytes) {
      return request.resource.size <= maxBytes;
    }

    function isAllowedFileSize(maxBytes) {
      return request.resource.size <= maxBytes;
    }

    /* ---------- OLD AVATAR PATHS - kept for compatibility ---------- */
    match /avatars/{uid}/{fileName} {
      allow read: if true;

      allow create, update: if isOwner(uid)
        && isImage()
        && isAllowedImageSize(300 * 1024);

      allow delete: if isOwner(uid);
    }

    match /avatars/{uid}/{allPaths=**} {
      allow read: if true;

      allow create, update: if isOwner(uid)
        && isImage()
        && isAllowedImageSize(300 * 1024);

      allow delete: if isOwner(uid);
    }

    /* ---------- NEW PROFILE IMAGE PATH ---------- */
    /* Current optimized avatar path:
       profile_images/{uid}/avatar.webp
       User can replace same avatar file, max 300 KB.
    */
    match /profile_images/{uid}/{fileName} {
      allow read: if true;

      allow create, update: if isOwner(uid)
        && isImage()
        && isAllowedImageSize(300 * 1024);

      allow delete: if isOwner(uid);
    }

    match /profile_images/{uid}/{allPaths=**} {
      allow read: if true;

      allow create, update: if isOwner(uid)
        && isImage()
        && isAllowedImageSize(300 * 1024);

      allow delete: if isOwner(uid);
    }

    /* ---------- OLD GENERAL IMAGE PATH - READ ONLY ---------- */
    /* Old path like:
       images/random-file-name
       Kept readable so old images still display.
       New uploads are blocked to prevent random large uploads.
    */
    match /images/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    /* ---------- OLD ARTICLE IMAGE PATHS - kept for compatibility ---------- */
    match /articles/{uid}/{fileName} {
      allow read: if true;

      allow create, update: if isOwner(uid)
        && isImage()
        && isAllowedImageSize(700 * 1024);

      allow delete: if isOwner(uid);
    }

    match /articles/{uid}/{allPaths=**} {
      allow read: if true;

      allow create, update: if isOwner(uid)
        && isImage()
        && isAllowedImageSize(700 * 1024);

      allow delete: if isOwner(uid);
    }

    /* ---------- NEW ARTICLE BODY IMAGES ---------- */
    /* Current optimized editor image path:
       article_images/{uid}/...
       Max 700 KB after compression.
    */
    match /article_images/{uid}/{fileName} {
      allow read: if true;

      allow create, update: if isOwner(uid)
        && isImage()
        && isAllowedImageSize(700 * 1024);

      allow delete: if isOwner(uid);
    }

    match /article_images/{uid}/{allPaths=**} {
      allow read: if true;

      allow create, update: if isOwner(uid)
        && isImage()
        && isAllowedImageSize(700 * 1024);

      allow delete: if isOwner(uid);
    }

    /* ---------- ARTICLE COVER IMAGES ---------- */
    match /article_covers/{uid}/{articleId}/{fileName} {
      allow read: if true;

      allow create, update: if isOwner(uid)
        && isImage()
        && isAllowedImageSize(700 * 1024);

      allow delete: if isOwner(uid);
    }

    match /article_covers/{uid}/{allPaths=**} {
      allow read: if true;

      allow create, update: if isOwner(uid)
        && isImage()
        && isAllowedImageSize(700 * 1024);

      allow delete: if isOwner(uid);
    }

    /* ---------- FILE ATTACHMENTS ---------- */
    match /files/{uid}/{fileName} {
      allow read: if true;

      allow create, update: if isOwner(uid)
        && isAllowedFileSize(2 * 1024 * 1024);

      allow delete: if isOwner(uid);
    }

    match /files/{uid}/{allPaths=**} {
      allow read: if true;

      allow create, update: if isOwner(uid)
        && isAllowedFileSize(2 * 1024 * 1024);

      allow delete: if isOwner(uid);
    }

    /* ---------- SAFETY FALLBACK ---------- */
    match /{allPaths=**} {
      allow read: if true;

      // No random uploads outside approved folders.
      allow write: if false;
    }
  }
}